# ============================================
# AI Document Q&A Application - Environment Variables
# ============================================

# Application
APP_NAME=AI Document Q&A API
APP_VERSION=1.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_doc_qa

# Redis (Cache & Session Storage)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# xAI Grok API (OpenAI-compatible)
XAI_API_KEY=your-xai-api-key
MODEL_NAME=grok-2-latest
XAI_BASE_URL=https://api.x.ai/v1

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-doc-qa-files

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# File Upload Configuration
MAX_FILE_SIZE=524288000
ALLOWED_FILE_TYPES=pdf,mp3,mp4,wav,m4a,mov,avi

# Vector Search (FAISS)
FAISS_INDEX_PATH=/app/data/faiss_index
EMBEDDING_DIMENSION=1536
TOP_K_RESULTS=5

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
